{
  "manifest_version": 3,
  "name": "Jirator",
  "version": "1.3",
  "description": "Custom element styling with persistence",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_title": "Jirator",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content/content.css"
      ],
      "js": [
        "utils/storage.js",
        "utils/helpers.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}